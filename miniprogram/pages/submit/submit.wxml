<!--pages/submit/submit.wxml-->
<view class="submit-page">
  <!-- 标题 -->
  <view class="page-header">
    <text class="page-title">确认点单 ✨</text>
    <text class="page-subtitle">检查一下，没问题就下单吧</text>
  </view>

  <!-- 已选菜品列表 -->
  <view class="card order-card">
    <view class="card-title">🍽️ 已选菜品</view>
    <view class="order-list">
      <view class="order-item" wx:for="{{selectedItems}}" wx:key="name">
        <view class="order-item-left">
          <text class="order-item-name">{{item.name}}</text>
          <text class="order-item-category">{{item.category}}</text>
        </view>
        <text class="order-item-qty">×{{item.quantity}}</text>
      </view>
    </view>
    <view class="order-total">
      共 <text class="total-highlight">{{totalCount}}</text> 道菜
    </view>
  </view>

  <!-- 期望时间 -->
  <view class="card time-card">
    <view class="card-title">⏰ 期望时间</view>
    <view class="time-options">
      <view
        class="time-option {{expectTime === 'asap' ? 'active' : ''}}"
        bindtap="selectTime"
        data-time="asap"
      >
        <text class="time-emoji">🕐</text>
        <text class="time-label">尽快</text>
      </view>
      <view
        class="time-option {{expectTime === 'noon' ? 'active' : ''}}"
        bindtap="selectTime"
        data-time="noon"
      >
        <text class="time-emoji">☀️</text>
        <text class="time-label">中午</text>
      </view>
      <view
        class="time-option {{expectTime === 'dinner' ? 'active' : ''}}"
        bindtap="selectTime"
        data-time="dinner"
      >
        <text class="time-emoji">🌙</text>
        <text class="time-label">晚餐</text>
      </view>
      <picker mode="multiSelector" bindchange="onCustomTimeChange" value="{{customTimeIndex}}" range="{{customTimeRange}}">
        <view class="time-option {{expectTime === 'custom' ? 'active' : ''}}">
          <text class="time-emoji">📅</text>
          <text class="time-label">{{customTimeText || '自定义'}}</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 备注 -->
  <view class="card note-card">
    <view class="card-title">📝 备注</view>
    <textarea
      class="note-input"
      placeholder="想说点什么？比如'不要太辣'、'多加蒜'~"
      placeholder-class="note-placeholder"
      value="{{note}}"
      bindinput="onNoteInput"
      maxlength="200"
      auto-height
    ></textarea>
  </view>

  <!-- 心情标签（可选小功能） -->
  <view class="card mood-card">
    <view class="card-title">💖 今天的心情</view>
    <view class="mood-options">
      <view
        class="mood-item {{mood === item ? 'active' : ''}}"
        wx:for="{{moodList}}"
        wx:key="*this"
        bindtap="selectMood"
        data-mood="{{item}}"
      >{{item}}</view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-action">
    <button class="submit-btn" bindtap="submitOrder" loading="{{submitting}}">
      下单 💕
    </button>
  </view>
</view>

<!-- 成功弹窗 -->
<view class="success-modal" wx:if="{{showSuccess}}">
  <view class="success-content">
    <view class="hearts-container">
      <text class="heart h1">❤️</text>
      <text class="heart h2">💕</text>
      <text class="heart h3">💗</text>
      <text class="heart h4">❤️</text>
      <text class="heart h5">💕</text>
    </view>
    <text class="success-text">点单成功！</text>
    <text class="success-sub">已通知厨师开始准备~</text>
    <button class="btn-primary" bindtap="goToMessage">查看进度</button>
  </view>
</view>
