/* pages/menuAdmin/menuAdmin.wxss */

.menu-admin-page {
  min-height: 100vh;
  background: #F0F4FF;
  padding-bottom: calc(var(--spacing-xl) + env(safe-area-inset-bottom));
}

.page-header {
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, #4A90D2, #6EB5FF);
  color: #FFFFFF;
}

.page-title {
  display: block;
  font-size: var(--font-size-xxl);
  font-weight: 700;
  color: #FFFFFF;
}

.page-subtitle {
  display: block;
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.8);
  margin-top: var(--spacing-xs);
}

/* 分类标签栏 */
.category-tabs {
  background: #FFFFFF;
  padding: 0 var(--spacing-md);
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  margin-bottom: var(--spacing-md);
}

.tabs-scroll {
  width: 100%;
  white-space: nowrap;
}

.tab-list {
  display: flex;
  padding: var(--spacing-sm) 0;
}

.tab-item {
  display: inline-block;
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #4A90D2;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #4A90D2;
  border-radius: var(--radius-full);
}

/* 列表区 */
.menu-list {
  padding: var(--spacing-sm) var(--spacing-md);
}

.menu-card {
  display: flex;
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-md);
  align-items: center;
}

/* 图片区域 */
.menu-photo {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: #EAF0FF;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.photo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.placeholder-icon {
  font-size: 48rpx;
  margin-bottom: 4rpx;
}

.placeholder-text {
  font-size: 20rpx;
  color: #8DADC8;
}

/* 详情区 */
.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 140rpx;
}

.menu-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-switch {
  transform: scale(0.7);
  transform-origin: left center;
}

.status-text {
  font-size: var(--font-size-xs);
  margin-right: auto;
}

.status-text.on {
  color: #4CAF50;
}

.status-text.off {
  color: var(--color-text-light);
}

.delete-btn {
  font-size: var(--font-size-xs) !important;
  color: #E91E63 !important;
  background: #FCE4EC !important;
  padding: 6rpx 20rpx !important;
  margin: 0 !important;
  border-radius: var(--radius-full) !important;
}

.delete-btn::after {
  border: none;
}
