/* pages/order/order.wxss */

.order-page {
  padding-bottom: env(safe-area-inset-bottom);
  min-height: 100vh;
}

/* 欢迎栏 */
.welcome-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-lg) var(--spacing-md);
}

.welcome-text {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text);
}

.random-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-primary-bg);
  border-radius: var(--radius-full);
  padding: var(--spacing-sm) var(--spacing-md);
  transition: all 0.3s;
}

.random-btn:active {
  transform: scale(0.92);
}

.random-icon {
  font-size: 36rpx;
}

.random-text {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: 600;
}

/* 分类标签滚动 */
.category-scroll {
  white-space: nowrap;
  padding: 0 var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  width: 100%;
  box-sizing: border-box;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: var(--spacing-xs) 0;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-lg);
  background: var(--color-card);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.3s;
  min-width: 140rpx;
  flex-shrink: 0;
}

.category-item.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 129, 0.3);
}

.category-emoji {
  font-size: 44rpx;
}

.category-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.category-item.active .category-name {
  color: #FFFFFF;
  font-weight: 600;
}

/* 菜品区域 */
.food-section {
  padding: 0 var(--spacing-lg);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-sm) 0;
}

.title-emoji {
  font-size: 40rpx;
}

.title-text {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
}

/* 菜品列表 */
.food-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.food-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  opacity: 0;
  animation-fill-mode: forwards;
  transition: transform 0.2s;
  box-sizing: border-box;
}

.food-card:active {
  transform: scale(0.97);
}

.food-image-container {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  background: #fdfdfd;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.food-image {
  width: 100%;
  height: 100%;
  display: block;
}

.food-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF0F3, #FFE3E8);
}

.placeholder-emoji {
  font-size: 64rpx;
  opacity: 0.8;
}

.food-info {
  flex: 1;
  min-width: 0;
  padding: 0;
  text-align: left;
}

.food-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
}

/* 添加按钮 */
.add-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 129, 0.3);
  transition: all 0.3s;
}

.add-btn.added {
  background: linear-gradient(135deg, var(--color-success), #69DB7C);
  box-shadow: 0 4rpx 12rpx rgba(81, 207, 102, 0.3);
}

.add-btn:active {
  transform: scale(0.85);
}

.check-mark {
  font-size: 28rpx;
  font-weight: 700;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.qty-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.qty-btn.minus {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.qty-btn.plus {
  background: var(--color-primary);
  color: #FFFFFF;
}

.qty-num {
  font-size: var(--font-size-sm);
  font-weight: 700;
  min-width: 32rpx;
  text-align: center;
  color: var(--color-text);
}

/* 随机推荐弹窗 */
.random-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.random-content {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  width: 600rpx;
  animation: fadeInUp 0.3s ease-out;
}

.random-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  text-align: center;
  display: block;
  margin-bottom: var(--spacing-lg);
}

.random-items {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: var(--spacing-xl);
}

.random-item {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--radius-full);
  font-size: var(--font-size-md);
  font-weight: 500;
}

.random-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.random-actions .btn-secondary {
  flex: 1;
  padding: var(--spacing-md) 0;
}

.random-actions .btn-primary {
  flex: 1;
  padding: var(--spacing-md) 0;
}

/* 底部购物栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  background: var(--color-card);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
  z-index: 50;
}

.cart-bar.show {
  transform: translateY(0);
}

.cart-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cart-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  font-size: var(--font-size-sm);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-text {
  font-size: var(--font-size-md);
  color: var(--color-text);
  font-weight: 500;
}

.cart-arrow {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

.cart-submit-btn {
  background: linear-gradient(135deg, var(--color-primary), #FF4757);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-full);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-size-md);
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 129, 0.4);
}

.cart-submit-btn::after {
  border: none;
}

.cart-submit-btn:active {
  transform: scale(0.96);
}

/* 已选详情 */
.cart-detail {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  top: 0;
  z-index: 45;
  pointer-events: none;
}

.cart-detail.show {
  pointer-events: auto;
}

.cart-detail-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  opacity: 0;
  transition: opacity 0.3s;
}

.cart-detail.show .cart-detail-mask {
  opacity: 1;
}

.cart-detail-content {
  position: absolute;
  /* 调整底边距刚好被购物栏（120rpx）稍微盖住一点点形成整体连贯，下部安全距离由底部购物栏本身的 padding 实现填充 */
  bottom: calc(110rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: var(--color-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: var(--spacing-lg) var(--spacing-lg) 60rpx; /* 加一点底部内边距防贴边 */
  max-height: 60vh;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
}

.cart-detail.show .cart-detail-content {
  transform: translateY(0);
}

.cart-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-md);
  border-bottom: 2rpx solid var(--color-border);
}

.cart-detail-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
}

.cart-clear {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.cart-detail-list {
  max-height: 50vh;
}

.cart-detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 2rpx solid var(--color-border);
}

.cart-detail-item:last-child {
  border-bottom: none;
}

.item-name {
  font-size: var(--font-size-md);
  font-weight: 500;
}

.item-controls {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bottom-placeholder {
  height: 140rpx;
}
