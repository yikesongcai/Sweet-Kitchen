/* ==============================
   Sweet's 点单 - 全局样式
   配色方案：粉色暖色系
   ============================== */

/* CSS 变量 */
page {
  --color-primary: #FF6B81;
  --color-primary-light: #FF8FA3;
  --color-primary-lighter: #FFB3C1;
  --color-primary-bg: #FFF0F3;
  --color-secondary: #FFD6A5;
  --color-accent: #FF9F43;
  --color-bg: #FFF5F5;
  --color-card: #FFFFFF;
  --color-text: #2D2D2D;
  --color-text-secondary: #888888;
  --color-text-light: #BBBBBB;
  --color-border: #FFE4E8;
  --color-success: #51CF66;
  --color-warning: #FFD43B;
  --color-shadow: rgba(255, 107, 129, 0.12);

  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --radius-full: 999rpx;

  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  --font-size-xs: 22rpx;
  --font-size-sm: 26rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 44rpx;

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-size-md);
  line-height: 1.6;
}

/* 通用卡片样式 */
.card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin: var(--spacing-md) var(--spacing-lg);
  box-shadow: 0 4rpx 20rpx var(--color-shadow);
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-full);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-size-md);
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.3);
  transition: all 0.3s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 129, 0.2);
}

.btn-secondary {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border: none;
  border-radius: var(--radius-full);
  padding: var(--spacing-sm) var(--spacing-lg);
  font-size: var(--font-size-sm);
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.tag-success {
  background: #E8FAF0;
  color: var(--color-success);
}

.tag-warning {
  background: #FFF9E0;
  color: #F59F00;
}

/* 状态标签 */
.status-submitted {
  background: #FFF3E0;
  color: #FF9800;
}

.status-preparing {
  background: #E3F2FD;
  color: #2196F3;
}

.status-done {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-served {
  background: #FCE4EC;
  color: #E91E63;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacing-xl);
}

.empty-state .emoji {
  font-size: 120rpx;
  margin-bottom: var(--spacing-lg);
}

.empty-state .text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: var(--color-border);
  margin: var(--spacing-md) 0;
}

/* 动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  14% { transform: scale(1.3); }
  28% { transform: scale(1); }
  42% { transform: scale(1.3); }
  70% { transform: scale(1); }
}

.animate-fade-in {
  animation: fadeInUp 0.4s ease-out;
}

.animate-heart {
  animation: heartBeat 1s ease-in-out;
}
